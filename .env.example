AUTH_SECRET=change-this-to-a-long-random-secret
ATTENDANCE_CRON_SECRET=

MATCH_THRESHOLD=0.40
LOGIN_MATCH_THRESHOLD=0.40
ADMIN_MATCH_THRESHOLD=0.40
LOGIN_MATCH_MIN_MARGIN=0.06

INFERENCE_DEVICE=auto
TORCH_NUM_THREADS=4

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=your@email.com
SMTP_USE_TLS=true

GOOGLE_OAUTH_JSON=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

CORS_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1|192\.168\.\d{1,3}\.\d{1,3}|10\.\d{1,3}\.\d{1,3}\.\d{1,3}|172\.(1[6-9]|2\d|3[01])\.\d{1,3}\.\d{1,3})(:\d+)?
